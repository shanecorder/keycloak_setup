# =============================================================================
# Keycloak HPC Infrastructure — Master Configuration
# =============================================================================
# Sourced by: new_keycloak_setup.sh, new_configure_hpc.sh,
#             setup_hpc_ad.sh, test_hpc_auth.sh
#
# Protect this file:  chmod 640 config.env
# =============================================================================

# -----------------------------------------------------------------------------
# Keycloak server
# -----------------------------------------------------------------------------
KC_VERSION="26.2.5"
KC_FQDN="kc.hpc.moffitt.org"          # Public FQDN (behind Caddy reverse proxy)
KC_HOST="localhost"                     # Local bind address
KC_PORT="8080"
KC_INSTALL_DIR="/opt/keycloak"

KC_ADMIN_USER="admin"
KC_ADMIN_PASSWORD=""                   # REQUIRED — set before running new_keycloak_setup.sh
                                        # (script generates and writes one if left blank)

# -----------------------------------------------------------------------------
# PostgreSQL database  [SECRET]
# -----------------------------------------------------------------------------
POSTGRES_HOST="10.14.193.208"
POSTGRES_PORT="5432"
DB_NAME="keycloak"
DB_USER="keycloak"
DB_PASSWORD=""                         # REQUIRED — set to your PostgreSQL keycloak user password

# -----------------------------------------------------------------------------
# Realm & OIDC  (written by new_keycloak_setup.sh after KC starts)
# -----------------------------------------------------------------------------
REALM_NAME="hpc-infrastructure"

OIDC_DISCOVERY_URL="https://kc.hpc.moffitt.org/realms/hpc-infrastructure/.well-known/openid-configuration"
OIDC_ISSUER="https://kc.hpc.moffitt.org/realms/hpc-infrastructure"
OIDC_AUDIENCE="openondemand"

# -----------------------------------------------------------------------------
# Clients  (secrets written by new_configure_hpc.sh)
# -----------------------------------------------------------------------------
KC_OOD_CLIENT_ID="openondemand"
KC_OOD_CLIENT_SECRET=""                # Set by new_configure_hpc.sh

KC_CLI_CLIENT_ID="hpc-cli"             # Public ROPC client — no secret required

OOD_DOMAIN="hpc.moffitt.org"
OOD_URL="https://hpc.moffitt.org"

# -----------------------------------------------------------------------------
# Active Directory / LDAP Federation  [SECRET]
# -----------------------------------------------------------------------------
# Space-separated failover LDAP server URLs
AD_SERVER_URL="ldaps://pwad3019.hlm.ad.moffitt.usf.edu ldaps://pwad3018.hlm.ad.moffitt.usf.edu"

# Read-only service account (must have permission to search the user tree)
AD_BIND_DN="hpc-ldap-bind@moffitt.org"
AD_BIND_PASSWORD="XXXXXX"             # REQUIRED — replace with AD service account password

# User search base (OU containing HPC user accounts)
AD_USER_DN="OU=Users,OU=MCC,DC=hlm,DC=ad,DC=moffitt,DC=usf,DC=edu"

# LDAP filter — restricts sync to authorized HPC groups (mirrors sssd.conf)
# Comma-separated DNs and parentheses must be inside single quotes to prevent
# shell interpretation.
AD_CUSTOM_FILTER='(|(memberOf=CN=HPC Users,OU=DLs,OU=MCC,DC=hlm,DC=ad,DC=moffitt,DC=usf,DC=edu)(memberOf=CN=DeptIT-Cyber,OU=DLs,OU=MCC,DC=hlm,DC=ad,DC=moffitt,DC=usf,DC=edu)(memberOf=CN=scicompadmins,OU=Groups,OU=MCC,DC=hlm,DC=ad,DC=moffitt,DC=usf,DC=edu))'

# AD group that maps to the hpc-user realm role
AD_RESEARCHER_GROUP="CN=HPC Users,OU=DLs,OU=MCC,DC=hlm,DC=ad,DC=moffitt,DC=usf,DC=edu"

# LDAP schema defaults (Active Directory)
AD_USER_OBJECT_CLASS="user"
AD_UUID_ATTR="objectGUID"
AD_USERNAME_ATTR="sAMAccountName"
AD_FIRSTNAME_ATTR="givenName"
AD_LASTNAME_ATTR="sn"
AD_EMAIL_ATTR="mail"
AD_GROUP_OBJECT_CLASS="group"
AD_SYNC_INTERVAL="86400"              # Full sync period in seconds (0 = manual only)

# LDAPS truststore — PEM bundle created by setup_hpc_ad.sh (no password needed)
# Keycloak 26.x reads PEM files directly; no JKS/keytool required.
KC_LDAP_TRUSTSTORE_PEM="/opt/keycloak/conf/ldap-ad-ca.pem"